# ================================================================
#  .env.example — Docker Stack Template
#  Copy to .env, then fill in deployment-specific values.
#  Example: cp .env.example .env
# ================================================================

# ================================================================
#  CORE — Required for every deployment
# ================================================================

# Project name: used as docker project/network prefix + subdomain base + tailscale hostname
PROJECT_NAME=
PROJECT_NAME_TAILSCALE=

# Root domain — no http://, no trailing slash
DOMAIN=${PROJECT_NAME}.dpdns.org

# ================================================================
#  CI / REMOTE ENV — Used by pipeline sync and stop-listener scripts
# ================================================================
DOTENVRTDB_ROOT_URL=https://your-project-default-rtdb.region.firebasedatabase.app/env.json?auth=replace-me
DOTENVRTDB_SECRET=
DOTENVRTDB_PATH_URL=demo

DOTENVRTDB_URL=${DOTENVRTDB_ROOT_URL}/${DOTENVRTDB_PATH_URL}.json?auth=${DOTENVRTDB_SECRET}
STOP_LISTENER_ENABLED=true
STOP_FIREBASE_URL=${DOTENVRTDB_ROOT_URL}/${DOTENVRTDB_PATH_URL}-stop-id.json?auth=${DOTENVRTDB_SECRET}
# Firebase Realtime Database URL used to store both:
# - state key  (tailscaled.state backup)
# - certs key  (/var/lib/tailscale/certs backup)
TAILSCALE_KEEP_IP_FIREBASE_URL=${DOTENVRTDB_ROOT_URL}/${DOTENVRTDB_PATH_URL}-tailscale-keep-ip.json?auth=${DOTENVRTDB_SECRET}

# ================================================================
#  CADDY AUTH — Basic Auth protects routes by default
# ================================================================
# Basic auth username
CADDY_AUTH_USER=admin
# Generate with:
#   docker run --rm caddy:alpine caddy hash-password --plaintext "YourPassword"
CADDY_AUTH_HASH='$2a$14$replace-this-with-a-real-bcrypt-hash-value000000000000'
# Email for Caddy SSL via Let's Encrypt
CADDY_EMAIL=${CADDY_AUTH_USER}@${DOMAIN}

# ================================================================
#  APPLICATION — CollabMD
#  Quy ước comment:
#  - "Tác dụng": cấu hình ảnh hưởng tới app/sidecar như thế nào.
#  - "Ví dụ": giá trị mẫu có thể dùng khi triển khai.
#  - "Giá trị": liệt kê giá trị cố định khi biến chỉ chấp nhận một tập lựa chọn.
# ================================================================

# Tác dụng: image Docker dùng để chạy CollabMD cho mọi mode.
# Ví dụ: COLLABMD_IMAGE=ghcr.io/andes90/collabmd:latest hoặc ghcr.io/andes90/collabmd:v1.2.3
COLLABMD_IMAGE=ghcr.io/andes90/collabmd:latest

# Tác dụng: port CollabMD lắng nghe bên trong container; APP_PORT bên dưới phải trỏ theo biến này.
# Ví dụ: COLLABMD_PORT=1234
COLLABMD_PORT=1234
# Tác dụng: alias port nội bộ mà Compose/Caddy/healthcheck sử dụng; nên giữ bằng ${COLLABMD_PORT}.
# Ví dụ: APP_PORT=${COLLABMD_PORT}
APP_PORT=${COLLABMD_PORT}

# Tác dụng: port host legacy cho app local mode khi chưa đặt COLLABMD_LOCAL_HOST_PORT.
# Ví dụ: APP_HOST_PORT=1234
APP_HOST_PORT=1234

# Tác dụng: HTTP path dùng cho healthcheck CollabMD.
# Ví dụ: COLLABMD_HEALTH_PATH=/health
COLLABMD_HEALTH_PATH=/health
# Tác dụng: alias health path mà Compose healthcheck sử dụng; nên giữ bằng ${COLLABMD_HEALTH_PATH}.
# Ví dụ: HEALTH_PATH=${COLLABMD_HEALTH_PATH}
HEALTH_PATH=${COLLABMD_HEALTH_PATH}

# Tác dụng: môi trường Node.js của CollabMD.
# Giá trị: production | development | test
# Ví dụ: COLLABMD_NODE_ENV=production
COLLABMD_NODE_ENV=production
# Tác dụng: alias NODE_ENV cho runtime/container; nên giữ bằng ${COLLABMD_NODE_ENV}.
# Giá trị: production | development | test
# Ví dụ: NODE_ENV=${COLLABMD_NODE_ENV}
NODE_ENV=${COLLABMD_NODE_ENV}

# Tác dụng: thư mục gốc trên host để lưu dữ liệu bind mount của stack, gồm vault/cache/config.
# Ví dụ: DOCKER_VOLUMES_ROOT=./.docker-volumes hoặc /mnt/data/collabmd
DOCKER_VOLUMES_ROOT=./.docker-volumes

# Tác dụng: chiến lược đăng nhập mặc định cho CollabMD, có thể bị override theo từng mode.
# Giá trị: none | password | oidc
# Ví dụ: COLLABMD_AUTH_STRATEGY=password
COLLABMD_AUTH_STRATEGY=none
# Tác dụng: mật khẩu dùng khi COLLABMD_AUTH_STRATEGY=password; để trống khi dùng none/oidc.
# Ví dụ: COLLABMD_AUTH_PASSWORD=change-this-long-password
COLLABMD_AUTH_PASSWORD=
# Tác dụng: secret ký session/cookie; nên đặt chuỗi random dài khi bật auth.
# Ví dụ: COLLABMD_AUTH_SESSION_SECRET=$(openssl rand -hex 32)
COLLABMD_AUTH_SESSION_SECRET=
# Tác dụng: thời gian sống session theo milliseconds; để trống để dùng mặc định của app.
# Ví dụ: COLLABMD_AUTH_SESSION_MAX_AGE_MS=604800000
COLLABMD_AUTH_SESSION_MAX_AGE_MS=
# Tác dụng: OIDC client id khi COLLABMD_AUTH_STRATEGY=oidc.
# Ví dụ: COLLABMD_AUTH_OIDC_CLIENT_ID=123456789.apps.googleusercontent.com
COLLABMD_AUTH_OIDC_CLIENT_ID=
# Tác dụng: OIDC client secret khi COLLABMD_AUTH_STRATEGY=oidc.
# Ví dụ: COLLABMD_AUTH_OIDC_CLIENT_SECRET=GOCSPX-xxxxxxxx
COLLABMD_AUTH_OIDC_CLIENT_SECRET=
# Tác dụng: danh sách email được phép đăng nhập OIDC, phân tách bằng dấu phẩy; để trống nếu dùng domain allowlist.
# Ví dụ: COLLABMD_AUTH_OIDC_ALLOWED_EMAILS=alice@example.com,bob@example.com
COLLABMD_AUTH_OIDC_ALLOWED_EMAILS=
# Tác dụng: danh sách domain email được phép đăng nhập OIDC, phân tách bằng dấu phẩy.
# Ví dụ: COLLABMD_AUTH_OIDC_ALLOWED_DOMAINS=example.com,company.org
COLLABMD_AUTH_OIDC_ALLOWED_DOMAINS=
# Tác dụng: issuer URL của OIDC provider.
# Ví dụ: COLLABMD_AUTH_OIDC_ISSUER_URL=https://accounts.google.com
COLLABMD_AUTH_OIDC_ISSUER_URL=
# Tác dụng: tên cookie tạm dùng trong luồng OIDC; đổi khi chạy nhiều site chung domain để tránh đụng cookie.
# Ví dụ: COLLABMD_AUTH_OIDC_FLOW_COOKIE_NAME=collabmd_auth_flow
COLLABMD_AUTH_OIDC_FLOW_COOKIE_NAME=collabmd_auth_flow
# Tác dụng: base path nếu CollabMD chạy dưới subpath thay vì root.
# Ví dụ: COLLABMD_BASE_PATH=/docs
COLLABMD_BASE_PATH=
# Tác dụng: public origin mặc định cho app, có thể bị override theo từng mode.
# Ví dụ: COLLABMD_PUBLIC_BASE_URL=https://collabmd.example.com
COLLABMD_PUBLIC_BASE_URL=
# Tác dụng: public WebSocket origin nếu khác PUBLIC_BASE_URL.
# Ví dụ: COLLABMD_PUBLIC_WS_BASE_URL=wss://collabmd.example.com
COLLABMD_PUBLIC_WS_BASE_URL=
# Tác dụng: path WebSocket của CollabMD.
# Ví dụ: COLLABMD_WS_BASE_PATH=/ws
COLLABMD_WS_BASE_PATH=/ws
# Tác dụng: tự tạo trang khi click wiki link chưa tồn tại.
# Giá trị: true | false
# Ví dụ: COLLABMD_WIKI_LINK_AUTO_CREATE=true
COLLABMD_WIKI_LINK_AUTO_CREATE=true
# Tác dụng: URL Draw.io/diagrams.net nếu muốn tích hợp editor diagram riêng.
# Ví dụ: COLLABMD_DRAWIO_BASE_URL=https://embed.diagrams.net
COLLABMD_DRAWIO_BASE_URL=
# Tác dụng: URL PlantUML server mà CollabMD dùng để render sơ đồ.
# Ví dụ: COLLABMD_PLANTUML_SERVER_URL=http://collabmd-plantuml:8080
COLLABMD_PLANTUML_SERVER_URL=http://collabmd-plantuml:8080
# Tác dụng: port host expose PlantUML renderer để debug/truy cập nội bộ.
# Ví dụ: COLLABMD_PLANTUML_HOST_PORT=18082
COLLABMD_PLANTUML_HOST_PORT=18082
# Tác dụng: giới hạn số entry archive CollabMD xử lý/trả về để tránh quá tải.
# Ví dụ: COLLABMD_MAX_ARCHIVE_ENTRIES=10000
COLLABMD_MAX_ARCHIVE_ENTRIES=10000
# Tác dụng: giới hạn số dòng query base trả về.
# Ví dụ: COLLABMD_MAX_BASE_QUERY_ROWS=5000
COLLABMD_MAX_BASE_QUERY_ROWS=5000
# Tác dụng: giới hạn byte tối đa cho file download.
# Ví dụ: COLLABMD_MAX_DOWNLOAD_FILE_BYTES=268435456
COLLABMD_MAX_DOWNLOAD_FILE_BYTES=268435456
# Tác dụng: giới hạn byte tối đa cho lần sync ban đầu qua app/WebSocket.
# Ví dụ: COLLABMD_MAX_INITIAL_SYNC_BYTES=16777216
COLLABMD_MAX_INITIAL_SYNC_BYTES=16777216
# Tác dụng: timeout keep-alive HTTP của Node server, đơn vị milliseconds.
# Ví dụ: COLLABMD_HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
COLLABMD_HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
# Tác dụng: timeout nhận HTTP headers, đơn vị milliseconds.
# Ví dụ: COLLABMD_HTTP_HEADERS_TIMEOUT_MS=60000
COLLABMD_HTTP_HEADERS_TIMEOUT_MS=60000
# Tác dụng: timeout xử lý HTTP request, đơn vị milliseconds.
# Ví dụ: COLLABMD_HTTP_REQUEST_TIMEOUT_MS=30000
COLLABMD_HTTP_REQUEST_TIMEOUT_MS=30000
# Tác dụng: chu kỳ heartbeat WebSocket để phát hiện client mất kết nối, đơn vị milliseconds.
# Ví dụ: COLLABMD_WS_HEARTBEAT_INTERVAL_MS=30000
COLLABMD_WS_HEARTBEAT_INTERVAL_MS=30000
# Tác dụng: thời gian giữ room WebSocket sau khi idle trước khi dọn, đơn vị milliseconds.
# Ví dụ: COLLABMD_WS_ROOM_IDLE_GRACE_MS=60000
COLLABMD_WS_ROOM_IDLE_GRACE_MS=60000
# Tác dụng: giới hạn bufferedAmount WebSocket trước khi backpressure/ngắt để bảo vệ RAM.
# Ví dụ: COLLABMD_WS_MAX_BUFFERED_AMOUNT_BYTES=16777216
COLLABMD_WS_MAX_BUFFERED_AMOUNT_BYTES=16777216
# Tác dụng: kích thước payload WebSocket tối đa.
# Ví dụ: COLLABMD_WS_MAX_PAYLOAD_BYTES=16777216
COLLABMD_WS_MAX_PAYLOAD_BYTES=16777216

# ================================================================
#  COLLABMD LOCAL MODE — local host folder as vault
# ================================================================
# Tác dụng: bật/tắt mode local folder; đây là mode mặc định nếu không bật mode khác.
# Giá trị: true | false
# Ví dụ: COLLABMD_LOCAL_ENABLED=true
COLLABMD_LOCAL_ENABLED=true
# Tác dụng: thư mục vault trên host cho local mode; dữ liệu markdown/asset nằm ở đây.
# Ví dụ: COLLABMD_LOCAL_HOST_DIR=/mnt/data/collabmd/local/vault
COLLABMD_LOCAL_HOST_DIR=${DOCKER_VOLUMES_ROOT}/collabmd/local/vault
# Tác dụng: path vault bên trong container local mode; CollabMD đọc/ghi vào path này.
# Ví dụ: COLLABMD_LOCAL_CONTAINER_DIR=/data
COLLABMD_LOCAL_CONTAINER_DIR=/data
# Tác dụng: IP host bind direct port cho local mode; 127.0.0.1 an toàn hơn, 0.0.0.0 mở ra LAN.
# Ví dụ: COLLABMD_LOCAL_BIND_IP=127.0.0.1
COLLABMD_LOCAL_BIND_IP=127.0.0.1
# Tác dụng: port host direct cho local mode.
# Ví dụ: COLLABMD_LOCAL_HOST_PORT=1234
COLLABMD_LOCAL_HOST_PORT=1234
# Tác dụng: hostname/site Caddy route vào local mode.
# Ví dụ: COLLABMD_LOCAL_CADDY_SITE=https://collabmd-local.example.com
COLLABMD_LOCAL_CADDY_SITE=http://collabmd-local.${DOMAIN}
# Tác dụng: public base URL app tự quảng bá cho local mode.
# Ví dụ: COLLABMD_LOCAL_PUBLIC_BASE_URL=https://collabmd-local.example.com
COLLABMD_LOCAL_PUBLIC_BASE_URL=https://collabmd-local.${DOMAIN}
# Tác dụng: hostname nội bộ Tailscale/Caddy cho local mode; để trống nếu không dùng Tailscale site riêng.
# Ví dụ: COLLABMD_LOCAL_TAILSCALE_SITE=https://collabmd-local.tailnet.ts.net
COLLABMD_LOCAL_TAILSCALE_SITE=
# Tác dụng: auth riêng cho local mode; mặc định kế thừa COLLABMD_AUTH_STRATEGY.
# Giá trị: none | password | oidc
# Ví dụ: COLLABMD_LOCAL_AUTH_STRATEGY=password
COLLABMD_LOCAL_AUTH_STRATEGY=${COLLABMD_AUTH_STRATEGY}
# Tác dụng: password riêng cho local mode khi auth=password; mặc định kế thừa COLLABMD_AUTH_PASSWORD.
# Ví dụ: COLLABMD_LOCAL_AUTH_PASSWORD=local-only-password
COLLABMD_LOCAL_AUTH_PASSWORD=${COLLABMD_AUTH_PASSWORD}
# Tác dụng: tên session cookie riêng cho local mode để không đụng cookie với mode khác.
# Ví dụ: COLLABMD_LOCAL_AUTH_SESSION_COOKIE_NAME=collabmd_local_auth
COLLABMD_LOCAL_AUTH_SESSION_COOKIE_NAME=collabmd_local_auth
# Tác dụng: bật Git integration bên trong app local mode nếu vault local cũng là Git repo.
# Giá trị: true | false
# Ví dụ: COLLABMD_LOCAL_APP_GIT_ENABLED=false
COLLABMD_LOCAL_APP_GIT_ENABLED=false

# ================================================================
#  COLLABMD RCLONE MODE — rclone mount as vault
# ================================================================
# Tác dụng: bật/tắt mode rclone mount FUSE.
# Giá trị: true | false
# Ví dụ: COLLABMD_RCLONE_ENABLED=true
COLLABMD_RCLONE_ENABLED=false
# Tác dụng: remote:path rclone dùng làm vault.
# Ví dụ: COLLABMD_RCLONE_REMOTE=gdrive:notes/collabmd
COLLABMD_RCLONE_REMOTE=your-remote:collabmd-vault
# Tác dụng: thư mục chứa rclone.conf trên host nếu không dùng COLLABMD_RCLONE_CONFIG_B64.
# Ví dụ: COLLABMD_RCLONE_CONFIG_DIR=/mnt/secrets/rclone
COLLABMD_RCLONE_CONFIG_DIR=${DOCKER_VOLUMES_ROOT}/collabmd/rclone/config
# Tác dụng: nội dung rclone.conf đã base64 để cấu hình remote qua env/secret CI.
# Ví dụ: COLLABMD_RCLONE_CONFIG_B64=$(base64 -w0 rclone.conf)
# Lưu ý: phải là một dòng base64 hợp lệ, không dùng placeholder/xxxxx và không có newline.
COLLABMD_RCLONE_CONFIG_B64=
# Tác dụng: thư mục host nơi FUSE mount remote được gắn vào cho rclone mode.
# Ví dụ: COLLABMD_RCLONE_HOST_DIR=/mnt/data/collabmd/rclone/vault
COLLABMD_RCLONE_HOST_DIR=${DOCKER_VOLUMES_ROOT}/collabmd/rclone/vault
# Tác dụng: thư mục cache VFS của rclone mount trên host.
# Ví dụ: COLLABMD_RCLONE_CACHE_DIR=/mnt/cache/collabmd-rclone
COLLABMD_RCLONE_CACHE_DIR=${DOCKER_VOLUMES_ROOT}/collabmd/rclone/cache
# Tác dụng: path vault trong container CollabMD rclone mode.
# Ví dụ: COLLABMD_RCLONE_CONTAINER_DIR=/data
COLLABMD_RCLONE_CONTAINER_DIR=/data
# Tác dụng: IP host bind direct port cho rclone mode.
# Ví dụ: COLLABMD_RCLONE_BIND_IP=127.0.0.1
COLLABMD_RCLONE_BIND_IP=127.0.0.1
# Tác dụng: port host direct cho rclone mode.
# Ví dụ: COLLABMD_RCLONE_HOST_PORT=1235
COLLABMD_RCLONE_HOST_PORT=1235
# Tác dụng: hostname/site Caddy route vào rclone mode.
# Ví dụ: COLLABMD_RCLONE_CADDY_SITE=https://collabmd-rclone.example.com
COLLABMD_RCLONE_CADDY_SITE=http://collabmd-rclone.${DOMAIN}
# Tác dụng: public base URL app tự quảng bá cho rclone mode.
# Ví dụ: COLLABMD_RCLONE_PUBLIC_BASE_URL=https://collabmd-rclone.example.com
COLLABMD_RCLONE_PUBLIC_BASE_URL=https://collabmd-rclone.${DOMAIN}
# Tác dụng: hostname nội bộ Tailscale/Caddy cho rclone mode; để trống nếu không dùng.
# Ví dụ: COLLABMD_RCLONE_TAILSCALE_SITE=https://collabmd-rclone.tailnet.ts.net
COLLABMD_RCLONE_TAILSCALE_SITE=
# Tác dụng: auth riêng cho rclone mode; mặc định kế thừa COLLABMD_AUTH_STRATEGY.
# Giá trị: none | password | oidc
# Ví dụ: COLLABMD_RCLONE_AUTH_STRATEGY=oidc
COLLABMD_RCLONE_AUTH_STRATEGY=${COLLABMD_AUTH_STRATEGY}
# Tác dụng: password riêng cho rclone mode khi auth=password.
# Ví dụ: COLLABMD_RCLONE_AUTH_PASSWORD=rclone-mode-password
COLLABMD_RCLONE_AUTH_PASSWORD=${COLLABMD_AUTH_PASSWORD}
# Tác dụng: tên session cookie riêng cho rclone mode.
# Ví dụ: COLLABMD_RCLONE_AUTH_SESSION_COOKIE_NAME=collabmd_rclone_auth
COLLABMD_RCLONE_AUTH_SESSION_COOKIE_NAME=collabmd_rclone_auth
# Tác dụng: bật Git integration bên trong app rclone mode nếu vault rclone chứa Git repo.
# Giá trị: true | false
# Ví dụ: COLLABMD_RCLONE_APP_GIT_ENABLED=false
COLLABMD_RCLONE_APP_GIT_ENABLED=false
# Tác dụng: chế độ VFS cache của rclone mount, ảnh hưởng hiệu năng và độ an toàn ghi file.
# Giá trị: off | minimal | writes | full
# Ví dụ: COLLABMD_RCLONE_VFS_CACHE_MODE=writes
COLLABMD_RCLONE_VFS_CACHE_MODE=writes
# Tác dụng: thời gian cache directory listing của rclone mount.
# Ví dụ: COLLABMD_RCLONE_DIR_CACHE_TIME=1m hoặc 30s
COLLABMD_RCLONE_DIR_CACHE_TIME=1m
# Tác dụng: chu kỳ rclone poll thay đổi từ remote nếu backend hỗ trợ.
# Ví dụ: COLLABMD_RCLONE_POLL_INTERVAL=1m
COLLABMD_RCLONE_POLL_INTERVAL=1m
# Tác dụng: umask cho file tạo qua rclone mount.
# Ví dụ: COLLABMD_RCLONE_UMASK=002
COLLABMD_RCLONE_UMASK=002
# Tác dụng: mức log của rclone mount sidecar.
# Giá trị: DEBUG | INFO | NOTICE | ERROR
# Ví dụ: COLLABMD_RCLONE_LOG_LEVEL=INFO
COLLABMD_RCLONE_LOG_LEVEL=INFO
# Tác dụng: tham số rclone mount bổ sung, dùng khi cần tuning backend cụ thể.
# Ví dụ: COLLABMD_RCLONE_EXTRA_ARGS=--drive-chunk-size 64M --transfers 8
COLLABMD_RCLONE_EXTRA_ARGS=

# ================================================================
#  COLLABMD RCLONE RUNNER-SAFE MODE — local disk + rclone sync
#  Recommended for GitHub Actions/Azure Pipelines because it avoids
#  privileged FUSE mounts. The app uses fast local disk and a sidecar
#  continuously pushes/pulls data with rclone.
# ================================================================
# Tác dụng: bật/tắt runner-safe mode không dùng FUSE; phù hợp CI runner tự recycle.
# Giá trị: true | false
# Ví dụ: COLLABMD_RCLONE_RUNNER_ENABLED=true
COLLABMD_RCLONE_RUNNER_ENABLED=false
# Tác dụng: thư mục vault local trên host/runner; app ghi nhanh vào đây trước khi sidecar sync remote.
# Ví dụ: COLLABMD_RCLONE_RUNNER_HOST_DIR=/home/runner/work/collabmd-vault
COLLABMD_RCLONE_RUNNER_HOST_DIR=${DOCKER_VOLUMES_ROOT}/collabmd/rclone-runner/vault
# Tác dụng: path vault trong container runner-safe app.
# Ví dụ: COLLABMD_RCLONE_RUNNER_CONTAINER_DIR=/data
COLLABMD_RCLONE_RUNNER_CONTAINER_DIR=/data
# Tác dụng: IP host bind direct port cho runner-safe mode.
# Ví dụ: COLLABMD_RCLONE_RUNNER_BIND_IP=127.0.0.1
COLLABMD_RCLONE_RUNNER_BIND_IP=127.0.0.1
# Tác dụng: port host direct cho runner-safe mode.
# Ví dụ: COLLABMD_RCLONE_RUNNER_HOST_PORT=1237
COLLABMD_RCLONE_RUNNER_HOST_PORT=1237
# Tác dụng: hostname/site Caddy route vào runner-safe app.
# Ví dụ: COLLABMD_RCLONE_RUNNER_CADDY_SITE=https://collabmd-runner.example.com
COLLABMD_RCLONE_RUNNER_CADDY_SITE=http://collabmd-rclone-runner.${DOMAIN}
# Tác dụng: public base URL app tự quảng bá cho runner-safe mode.
# Ví dụ: COLLABMD_RCLONE_RUNNER_PUBLIC_BASE_URL=https://collabmd-runner.example.com
COLLABMD_RCLONE_RUNNER_PUBLIC_BASE_URL=https://collabmd-rclone-runner.${DOMAIN}
# Tác dụng: hostname nội bộ Tailscale/Caddy cho runner-safe mode; để trống nếu không dùng.
# Ví dụ: COLLABMD_RCLONE_RUNNER_TAILSCALE_SITE=https://collabmd-runner.tailnet.ts.net
COLLABMD_RCLONE_RUNNER_TAILSCALE_SITE=
# Tác dụng: auth riêng cho runner-safe mode; mặc định kế thừa rclone/common auth.
# Giá trị: none | password | oidc
# Ví dụ: COLLABMD_RCLONE_RUNNER_AUTH_STRATEGY=password
COLLABMD_RCLONE_RUNNER_AUTH_STRATEGY=${COLLABMD_RCLONE_AUTH_STRATEGY}
# Tác dụng: password riêng cho runner-safe mode khi auth=password.
# Ví dụ: COLLABMD_RCLONE_RUNNER_AUTH_PASSWORD=runner-mode-password
COLLABMD_RCLONE_RUNNER_AUTH_PASSWORD=${COLLABMD_RCLONE_AUTH_PASSWORD}
# Tác dụng: tên session cookie riêng cho runner-safe mode.
# Ví dụ: COLLABMD_RCLONE_RUNNER_AUTH_SESSION_COOKIE_NAME=collabmd_rclone_runner_auth
COLLABMD_RCLONE_RUNNER_AUTH_SESSION_COOKIE_NAME=collabmd_rclone_runner_auth
# Tác dụng: bật Git integration bên trong runner-safe app nếu vault local là Git repo.
# Giá trị: true | false
# Ví dụ: COLLABMD_RCLONE_RUNNER_APP_GIT_ENABLED=false
COLLABMD_RCLONE_RUNNER_APP_GIT_ENABLED=false
# Tác dụng: kéo remote về local trước khi app được xem là sẵn sàng; tránh runner mới bắt đầu từ thư mục rỗng.
# Giá trị: true | false
# Ví dụ: COLLABMD_RCLONE_RUNNER_INITIAL_PULL=true
COLLABMD_RCLONE_RUNNER_INITIAL_PULL=true
# Tác dụng: chu kỳ upload local -> remote của sidecar, đơn vị giây; giảm số này để giảm RPO.
# Ví dụ: COLLABMD_RCLONE_RUNNER_SYNC_INTERVAL_SEC=20
COLLABMD_RCLONE_RUNNER_SYNC_INTERVAL_SEC=20
# Tác dụng: bật/tắt kéo thay đổi từ remote về local định kỳ khi có nguồn khác cùng ghi.
# Giá trị: true | false
# Ví dụ: COLLABMD_RCLONE_RUNNER_PULL_REMOTE_CHANGES=true
COLLABMD_RCLONE_RUNNER_PULL_REMOTE_CHANGES=true
# Tác dụng: chu kỳ pull remote -> local của sidecar, đơn vị giây.
# Ví dụ: COLLABMD_RCLONE_RUNNER_PULL_INTERVAL_SEC=120
COLLABMD_RCLONE_RUNNER_PULL_INTERVAL_SEC=120
# Tác dụng: cho phép xóa file remote khi local đã xóa file; false an toàn hơn vì dùng rclone copy không delete.
# Giá trị: true | false
# Ví dụ: COLLABMD_RCLONE_RUNNER_DELETE_REMOTE=false
COLLABMD_RCLONE_RUNNER_DELETE_REMOTE=false
# Tác dụng: tham số rclone copy/sync bổ sung để tuning hiệu năng upload/pull.
# Ví dụ: COLLABMD_RCLONE_RUNNER_SYNC_EXTRA_ARGS="--fast-list --metadata --transfers 8 --checkers 16"
COLLABMD_RCLONE_RUNNER_SYNC_EXTRA_ARGS="--fast-list --metadata --transfers 8 --checkers 16"
# Tác dụng: thời gian Docker chờ app dừng graceful để sidecar có cơ hội flush khi runner stop/recycle.
# Ví dụ: COLLABMD_RCLONE_RUNNER_STOP_GRACE_PERIOD=30s
COLLABMD_RCLONE_RUNNER_STOP_GRACE_PERIOD=30s
# Tác dụng: remote backup root không overlap dùng trước khi overwrite remote; để trống để tự suy ra sibling backup path.
# Ví dụ: COLLABMD_RCLONE_RUNNER_BACKUP_DIR=gdrive:notes/.collabmd-runner-backups/collabmd
COLLABMD_RCLONE_RUNNER_BACKUP_DIR=

# ================================================================
#  COLLABMD GIT MODE — private git repo bootstrap as vault
# ================================================================
# Tác dụng: bật/tắt mode Git private repo.
# Giá trị: true | false
# Ví dụ: COLLABMD_GIT_DEPLOY_ENABLED=true
COLLABMD_GIT_DEPLOY_ENABLED=false
# Tác dụng: thư mục checkout/vault Git trên host.
# Ví dụ: COLLABMD_GIT_HOST_DIR=/mnt/data/collabmd/git/vault
COLLABMD_GIT_HOST_DIR=${DOCKER_VOLUMES_ROOT}/collabmd/git/vault
# Tác dụng: thư mục host chứa secret file Git SSH/known_hosts nếu dùng file-based secrets.
# Ví dụ: COLLABMD_GIT_SECRETS_DIR=/mnt/secrets/collabmd-git
COLLABMD_GIT_SECRETS_DIR=${DOCKER_VOLUMES_ROOT}/collabmd/git/secrets
# Tác dụng: path vault/checkout bên trong container Git mode.
# Ví dụ: COLLABMD_GIT_CONTAINER_DIR=/data
COLLABMD_GIT_CONTAINER_DIR=/data
# Tác dụng: IP host bind direct port cho Git mode.
# Ví dụ: COLLABMD_GIT_BIND_IP=127.0.0.1
COLLABMD_GIT_BIND_IP=127.0.0.1
# Tác dụng: port host direct cho Git mode.
# Ví dụ: COLLABMD_GIT_HOST_PORT=1236
COLLABMD_GIT_HOST_PORT=1236
# Tác dụng: hostname/site Caddy route vào Git mode.
# Ví dụ: COLLABMD_GIT_CADDY_SITE=https://collabmd-git.example.com
COLLABMD_GIT_CADDY_SITE=http://collabmd-git.${DOMAIN}
# Tác dụng: public base URL app tự quảng bá cho Git mode.
# Ví dụ: COLLABMD_GIT_PUBLIC_BASE_URL=https://collabmd-git.example.com
COLLABMD_GIT_PUBLIC_BASE_URL=https://collabmd-git.${DOMAIN}
# Tác dụng: hostname nội bộ Tailscale/Caddy cho Git mode; để trống nếu không dùng.
# Ví dụ: COLLABMD_GIT_TAILSCALE_SITE=https://collabmd-git.tailnet.ts.net
COLLABMD_GIT_TAILSCALE_SITE=
# Tác dụng: auth riêng cho Git mode; mặc định kế thừa COLLABMD_AUTH_STRATEGY.
# Giá trị: none | password | oidc
# Ví dụ: COLLABMD_GIT_AUTH_STRATEGY=oidc
COLLABMD_GIT_AUTH_STRATEGY=${COLLABMD_AUTH_STRATEGY}
# Tác dụng: password riêng cho Git mode khi auth=password.
# Ví dụ: COLLABMD_GIT_AUTH_PASSWORD=git-mode-password
COLLABMD_GIT_AUTH_PASSWORD=${COLLABMD_AUTH_PASSWORD}
# Tác dụng: tên session cookie riêng cho Git mode.
# Ví dụ: COLLABMD_GIT_AUTH_SESSION_COOKIE_NAME=collabmd_git_auth
COLLABMD_GIT_AUTH_SESSION_COOKIE_NAME=collabmd_git_auth
# Tác dụng: bật Git integration trong app Git mode để CollabMD clone/pull/push repo.
# Giá trị: true | false
# Ví dụ: COLLABMD_GIT_APP_GIT_ENABLED=true
COLLABMD_GIT_APP_GIT_ENABLED=true
# Tác dụng: SSH URL private repo dùng bootstrap/sync vault.
# Ví dụ: COLLABMD_GIT_REPO_URL=git@github.com:your-org/your-private-vault.git
COLLABMD_GIT_REPO_URL=git@github.com:your-org/your-private-vault.git
# Tác dụng: private key SSH đã base64 để clone/push repo qua env secret.
# Ví dụ: COLLABMD_GIT_SSH_PRIVATE_KEY_B64=$(base64 -w0 ~/.ssh/id_ed25519)
COLLABMD_GIT_SSH_PRIVATE_KEY_B64=
# Tác dụng: path private key SSH bên trong container nếu dùng file-based secret; ưu tiên hơn B64 khi cùng đặt.
# Ví dụ: COLLABMD_GIT_SSH_PRIVATE_KEY_FILE=/run/secrets/collabmd/id_ed25519
COLLABMD_GIT_SSH_PRIVATE_KEY_FILE=
# Tác dụng: path known_hosts bên trong container để pin SSH host key; để trống thì app có thể accept-new.
# Ví dụ: COLLABMD_GIT_SSH_KNOWN_HOSTS_FILE=/run/secrets/collabmd/known_hosts
COLLABMD_GIT_SSH_KNOWN_HOSTS_FILE=
# Tác dụng: fallback Git author name khi không lấy từ OIDC user.
# Ví dụ: COLLABMD_GIT_USER_NAME=CollabMD Bot
COLLABMD_GIT_USER_NAME=
# Tác dụng: fallback Git author email khi không lấy từ OIDC user.
# Ví dụ: COLLABMD_GIT_USER_EMAIL=collabmd-bot@example.com
COLLABMD_GIT_USER_EMAIL=
# Tác dụng: tắt prompt Git tương tác để container không treo khi thiếu credential.
# Giá trị: 0 | 1 (0 = không prompt, 1 = cho phép prompt)
# Ví dụ: COLLABMD_GIT_TERMINAL_PROMPT=0
COLLABMD_GIT_TERMINAL_PROMPT=0
# Tác dụng: khai báo Git safe.directory để tránh lỗi dubious ownership với bind mount.
# Ví dụ: COLLABMD_GIT_SAFE_DIRECTORY=/data
COLLABMD_GIT_SAFE_DIRECTORY=${COLLABMD_GIT_CONTAINER_DIR}
# Tác dụng: bật sidecar chỉnh `.git/info/exclude` để metadata CollabMD cần thiết hiện trong Git status.
# Giá trị: true | false
# Ví dụ: COLLABMD_GIT_META_SYNC_ENABLED=true
COLLABMD_GIT_META_SYNC_ENABLED=false
# Tác dụng: image dùng chạy sidecar Git metadata sync.
# Ví dụ: COLLABMD_GIT_META_SYNC_IMAGE=alpine/git:latest
COLLABMD_GIT_META_SYNC_IMAGE=alpine/git:latest
# Tác dụng: chu kỳ sidecar kiểm tra/cập nhật exclude, đơn vị giây.
# Ví dụ: COLLABMD_GIT_META_SYNC_INTERVAL_SEC=30
COLLABMD_GIT_META_SYNC_INTERVAL_SEC=30
# Tác dụng: chạy metadata sync một lần rồi thoát, hữu ích trong job CI kiểm tra.
# Giá trị: true | false
# Ví dụ: COLLABMD_GIT_META_SYNC_ONESHOT=false
COLLABMD_GIT_META_SYNC_ONESHOT=false
# Tác dụng: cho phép track `.collabmd/comments/**/*.json` để comment đi theo Git.
# Giá trị: true | false
# Ví dụ: COLLABMD_GIT_TRACK_COLLABMD_COMMENTS=true
COLLABMD_GIT_TRACK_COLLABMD_COMMENTS=true
# Tác dụng: cho phép track `.collabmd/yjs/`; thường nên false vì dữ liệu runtime/binary dễ churn/conflict.
# Giá trị: true | false
# Ví dụ: COLLABMD_GIT_TRACK_COLLABMD_YJS=false
COLLABMD_GIT_TRACK_COLLABMD_YJS=false
# Tác dụng: cho phép track `.collabmd/pull-backups/`; thường nên false để tránh commit backup tạm.
# Giá trị: true | false
# Ví dụ: COLLABMD_GIT_TRACK_COLLABMD_PULL_BACKUPS=false
COLLABMD_GIT_TRACK_COLLABMD_PULL_BACKUPS=false


# ================================================================
#  FEATURE FLAGS — Enable or disable optional services
# ================================================================
ENABLE_DOZZLE=true
ENABLE_FILEBROWSER=true
ENABLE_WEBSSH=true
ENABLE_TAILSCALE=false
# ================================================================
#  OPS PORTS — Dozzle/Filebrowser/WebSSH local + Tailnet access
# ================================================================
# Host ports for ops services (used by compose.ops.yml)
DOZZLE_HOST_PORT=18080
FILEBROWSER_HOST_PORT=18081
WEBSSH_HOST_PORT=17681
# Bind IP for ops service ports:
# - 127.0.0.1: localhost only (safe default)
# - 0.0.0.0: allow direct access via Tailscale/LAN host IP
OPS_HOST_BIND_IP=0.0.0.0

# ================================================================
#  DOCKER DEPLOY CODE — Optional self-deploy / app control sidecar
# ================================================================

# Keep false by default. When true, dc.sh adds the deploy-code Compose profile.
DOCKER_DEPLOY_CODE_ENABLED=false

# Sidecar UI/API ports:
# - DOCKER_DEPLOY_CODE_PORT is inside the container.
# - DOCKER_DEPLOY_CODE_HOST_PORT is direct host/Tailnet access.
DOCKER_DEPLOY_CODE_PORT=53999
DOCKER_DEPLOY_CODE_HOST_PORT=15399

# Public Cloudflare/Caddy hostname for the Deploy Code UI.
# Add the same hostname to cloudflared/config.yml ingress.
DOCKER_DEPLOY_CODE_CADDY_HOSTS=deploy.${DOMAIN}

# API token is strongly recommended when exposed beyond localhost.
# Leave blank while disabled; fill a long random value before enabling.
DOCKER_DEPLOY_CODE_API_TOKEN=
DOCKER_DEPLOY_CODE_REQUIRE_TOKEN=true

# Repo/Git: sidecar mounts this repo into /workspace and uses existing git auth.
DOCKER_DEPLOY_CODE_REPO_DIR=/workspace
DOCKER_DEPLOY_CODE_REMOTE=origin
DOCKER_DEPLOY_CODE_BRANCH=main
DOCKER_DEPLOY_CODE_GIT_CLEAN=false

# Deploy target: rebuild/recreate only the configured Compose service(s).
DOCKER_DEPLOY_CODE_COMPOSE_SCRIPT=docker-compose/scripts/dc.sh
DOCKER_DEPLOY_CODE_DEPLOY_SERVICES=app,collabmd-rclone,collabmd-rclone-mount,collabmd-rclone-runner,collabmd-rclone-runner-sync,collabmd-git,collabmd-git-meta-sync,collabmd-plantuml
DOCKER_DEPLOY_CODE_RESTART_CONTAINERS=
DOCKER_DEPLOY_CODE_DEPLOY_COMMAND=
DOCKER_DEPLOY_CODE_POST_DEPLOY_COMMAND=

# Env commit keys updated after Git/ZIP deploy for cache/version tracking.
DOCKER_DEPLOY_CODE_ENV_FILE=.env
DOCKER_DEPLOY_CODE_ENV_COMMIT_ID_KEY=_DOTENVRTDB_RUNNER_COMMIT_ID
DOCKER_DEPLOY_CODE_ENV_COMMIT_SHORT_ID_KEY=_DOTENVRTDB_RUNNER_COMMIT_SHORT_ID
DOCKER_DEPLOY_CODE_ENV_COMMIT_AT_KEY=_DOTENVRTDB_RUNNER_COMMIT_AT

# Poll Git automatically. Prefer check-only before enabling auto deploy.
DOCKER_DEPLOY_CODE_POLL_ENABLED=false
DOCKER_DEPLOY_CODE_POLL_INTERVAL_SEC=300
DOCKER_DEPLOY_CODE_AUTO_DEPLOY_ON_CHANGE=false
DOCKER_DEPLOY_CODE_RUN_ON_START=false

# Container/service controls are allowlisted by default.
DOCKER_DEPLOY_CODE_CONTAINER_CONTROL_ENABLED=true
DOCKER_DEPLOY_CODE_CONTAINER_ALLOW_ALL=false
DOCKER_DEPLOY_CODE_SERVICE_ALLOWLIST=app,collabmd-rclone,collabmd-rclone-mount,collabmd-rclone-runner,collabmd-rclone-runner-sync,collabmd-git,collabmd-git-meta-sync,collabmd-plantuml
DOCKER_DEPLOY_CODE_CONTAINER_ALLOWLIST=collabmd-local,collabmd-rclone,collabmd-rclone-mount,collabmd-rclone-runner,collabmd-rclone-runner-sync,collabmd-git,collabmd-git-meta-sync,collabmd-plantuml,deploy-code
DOCKER_DEPLOY_CODE_CONTAINER_LOG_DEFAULT_LINES=200
DOCKER_DEPLOY_CODE_CONTAINER_LOG_MAX_LINES=2000
DOCKER_DEPLOY_CODE_CONTAINER_ACTION_TIMEOUT_SEC=600

# ZIP source deploy safety defaults.
DOCKER_DEPLOY_CODE_ZIP_MAX_MB=200
DOCKER_DEPLOY_CODE_ZIP_STRIP_TOP_LEVEL=true
DOCKER_DEPLOY_CODE_ZIP_DELETE_MISSING=false
DOCKER_DEPLOY_CODE_ZIP_BACKUP_BEFORE_APPLY=true
DOCKER_DEPLOY_CODE_ZIP_EXCLUDES=.git,.env,.docker-volumes,node_modules
DOCKER_DEPLOY_CODE_ZIP_DEPLOY_AFTER_APPLY=true

# Logs/backups inside sidecar; host volumes live under ${DOCKER_VOLUMES_ROOT}/deploy-code.
DOCKER_DEPLOY_CODE_LOG_DIR=/app/logs
DOCKER_DEPLOY_CODE_BACKUP_DIR=/app/backups
DOCKER_DEPLOY_CODE_TEMP_DIR=/tmp/deploy-code
DOCKER_DEPLOY_CODE_LOG_TAIL_LINES=200

# ================================================================
#  CLOUDFLARE TUNNEL — Public ingress mapping
# ================================================================

# Tunnel name used by Cloudflare / sync tooling
CLOUDFLARED_TUNNEL_NAME=${PROJECT_NAME}-tunnel-name

# Public hostnames exposed through the tunnel
CLOUDFLARED_TUNNEL_HOSTNAME_1=${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_2=main.${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_3=ttyd.${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_4=dozzle.${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_5=files.${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_6=deploy.${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_7=collabmd-local.${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_8=collabmd-rclone.${DOMAIN}
CLOUDFLARED_TUNNEL_HOSTNAME_9=collabmd-git.${DOMAIN}

# Internal services behind each hostname
CLOUDFLARED_TUNNEL_SERVICE_1=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_2=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_3=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_4=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_5=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_6=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_7=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_8=http://caddy:80
CLOUDFLARED_TUNNEL_SERVICE_9=http://caddy:80

# CI sync value for cloudflared/credentials.json
CLOUDFLARED_TUNNEL_CREDENTIALS_BASE64=file:base64:./cloudflared/credentials.json

# ================================================================
#  TAILSCALE — Only required if ENABLE_TAILSCALE=true
# ================================================================

# Optional: OAuth client ID for tailscale/tailscale-init.js
# Get from: https://login.tailscale.com/admin/settings/keys (Trust credentials)
# If using tailscale-init / keep-ip OAuth flow, set:
#   TAILSCALE_CLIENTID=<OAuth client ID>
#   TAILSCALE_AUTHKEY=<OAuth client secret, tskey-client-...>
TAILSCALE_CLIENTID=
# Get from: https://login.tailscale.com/admin/settings/keys
# Use Reusable + Ephemeral for CI runners.
# Auth key used by tailscale container to join tailnet and by scripts to request access token.
TAILSCALE_AUTHKEY=
# ACL tags for this node, example: tag:ci,tag:container
TAILSCALE_TAGS=tag:container
# Optional: whether tailscaled should manage in-container DNS on `tailscale up`
# false de tranh loi "rename /etc/resolv.conf: device or resource busy" trong container runtime
TAILSCALE_ACCEPT_DNS=false
# Owners used when tailscale-init creates missing tagOwners
TAILSCALE_TAG_OWNERS=autogroup:admin
# Tailnet DNS suffix from Tailscale admin → DNS page
TAILSCALE_TAILNET_DOMAIN=
# Used to auto-generate tailscale/serve.json (TS_SERVE_CONFIG) for Tailscale HTTPS.
# Optional: tailnet identifier used by tailscale-init API calls (default: -)
TAILSCALE_TS_TAILNET=-
# Optional: output path for generated serve config
TAILSCALE_SERVE_JSON_PATH=./tailscale/serve.json
# Optional: local upstream for Tailscale Serve proxy
TAILSCALE_SERVE_PROXY=http://127.0.0.1:80
# Keep same Tailscale identity/IP across restart by backing up tailscaled.state
# true  = enable backup/restore + remove existing hostname before start
# false = disable this behavior
TAILSCALE_KEEP_IP_ENABLE=false
# Optional: remove existing device(s) matching PROJECT_NAME before start
# If this var is missing/empty, runtime falls back to TAILSCALE_KEEP_IP_ENABLE.
# Set true to remove hostname even when KEEP_IP is false.
TAILSCALE_KEEP_IP_REMOVE_HOSTNAME_ENABLE=false
# Optional certs directory override (default: /var/lib/tailscale/certs)
TAILSCALE_KEEP_IP_CERTS_DIR=/var/lib/tailscale/certs
# Optional backup interval for keep-ip sidecar (seconds)
TAILSCALE_KEEP_IP_INTERVAL_SEC=30
# Optional: local ACL JSON/HuJSON file to merge missing tagOwners
TAILSCALE_ACL_JSON_PATH=./tailscale/acl.sample.hujson
# Optional watchdog mode:
# - monitor: chi log/canh bao, KHONG auto-heal
# - heal: cho phep reconnect + dns fix
TAILSCALE_WATCHDOG_MODE=heal
# Optional watchdog interval (seconds)
TAILSCALE_WATCHDOG_INTERVAL_SEC=30
# Optional repeat warning cadence (failed cycles)
TAILSCALE_WATCHDOG_ALERT_EVERY=5
# Optional periodic healthy log cadence (0 = moi cycle)
TAILSCALE_WATCHDOG_LOG_OK_EVERY=10
# Optional netcheck snapshot in warning logs
TAILSCALE_WATCHDOG_NETCHECK=true
# Optional minimum seconds between auto-reconnect attempts
TAILSCALE_WATCHDOG_RECONNECT_MIN_SEC=60
# Optional failed cycles before auto-heal starts
TAILSCALE_WATCHDOG_HEAL_AFTER_STREAK=2
# Optional: pass --accept-dns to `tailscale up`; false de tranh loi resolv.conf busy
TAILSCALE_WATCHDOG_UP_ACCEPT_DNS=false
# Optional DNS file inspection in sidecar (mac dinh false trong compose, tranh false-positive)
# TAILSCALE_WATCHDOG_DNS_CHECK=false
# Optional socket path (phu hop voi runtime thuc te)
# TAILSCALE_SOCKET=/tmp/tailscaled.sock




# ================================================================
#  RUNTIME — Auto-set by CI scripts. Do NOT edit manually.
# ================================================================

# CUR_OS=linux
# DOCKER_SOCK=/var/run/docker.sock
# COMPOSE_PROJECT_NAME=docker-stack-template
# CUR_WHOAMI=runner
# CUR_WORK_DIR=/home/runner/work
# WSL_WORKSPACE=/mnt/c/path/to/workspace
